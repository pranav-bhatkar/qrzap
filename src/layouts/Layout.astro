---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import PostHog from "../components/posthog.astro";
import Header from "../components/Header.astro";

interface Props {
  title: string;
  description?: string;
  hideHeader?: boolean;
}

const {
  title,
  description = "Free QR code generator with web UI, REST API, and MCP server. Supports URL, WiFi, phone, email, SMS, vCard.",
  hideHeader = false,
} = Astro.props;
const canonicalURL = new URL(
  Astro.url.pathname,
  Astro.site || "https://qrzap.fun",
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <!-- Prevent flash: apply theme before paint -->
    <script is:inline>
      (function() {
        var t = localStorage.getItem('theme');
        if (t === 'light') { document.documentElement.classList.remove('dark'); }
        else { document.documentElement.classList.add('dark'); }
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ClientRouter />

    <!-- SEO -->
    <meta name="author" content="Pranav Bhatkar" />
    <meta
      name="keywords"
      content="QR code generator, free QR code, WiFi QR, vCard QR, MCP server, REST API, QR code API, qrzap"
    />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#09090b" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://qrzap.fun/og.png" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="QRzap" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://qrzap.fun/og.png" />

    <!-- Structured Data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebApplication",
        name: "QRzap",
        url: "https://qrzap.fun",
        description: description,
        applicationCategory: "UtilityApplication",
        operatingSystem: "Any",
        offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
        author: {
          "@type": "Person",
          name: "Pranav Bhatkar",
          url: "https://pranavbhatkar.me",
        },
      })}
    />

    <!-- PostHog Analytics -->
    <PostHog />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-CT9SKT4PML"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-CT9SKT4PML");
    </script>
  </head>
  <body class="min-h-screen antialiased flex flex-col">
    <div class="hidden lg:flex max-w-6xl mx-auto relative">
      <div
        class="fixed top-0 bottom-0 w-4 stripe-pattern border-x border-border/40 z-40"
        style="left: calc((100vw - 72rem) / 2 - 1rem);"
      >
      </div>
      <div
        class="fixed top-0 bottom-0 w-4 stripe-pattern border-x border-border/40 z-40"
        style="right: calc((100vw - 72rem) / 2 - 1rem);"
      >
      </div>
    </div>

    {!hideHeader && <Header />}

    <div class="flex-grow" transition:animate="fade">
      <slot />
    </div>

    <footer>
      <div
        class="flex flex-col items-center gap-4 px-5 py-10 max-w-6xl mx-auto"
      >
        <a
          href="https://www.pranavbhatkar.me"
          aria-label="Pranav Bhatkar's Portfolio"
          class="logo font-medium font-inter"
        >
          <p class="copyright">&copy;</p>
          <div class="name">
            <p class="codeBy">Code by</p>
            <p class="pranav">Pranav</p>
            <p class="bhatkar">Bhatkar</p>
          </div>
        </a>
        <div
          class="flex items-center gap-4 text-[9px] uppercase tracking-[0.2em] text-muted-foreground/60"
        >
          <span>QRzap</span>
          <span>&middot;</span>
          <span>&copy; {new Date().getFullYear()}</span>
          <span>&middot;</span>
          <span>No data stored</span>
        </div>
      </div>
      <div class="max-w-6xl mx-auto">
        <div
          class="relative w-full h-4 border-y border-border stripe-pattern md:h-6"
        >
        </div>
      </div>
    </footer>
  </body>
</html>
